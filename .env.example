# PostgreSQL
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental_secret
POSTGRES_DB=rental_manager

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# Keycloak Realm / Client (used by backend + frontend)
KEYCLOAK_REALM=rental
KEYCLOAK_CLIENT_ID=rental-frontend

# Public URL of Keycloak (reachable from the browser) – served via Caddy at /auth
# Leave unset: oidc.js uses window.location.origin+"/auth" automatically, which
# works for both local dev (http://localhost) and GitHub Codespaces.
# VITE_KEYCLOAK_URL=https://example.com/auth

# Frontend API base – relative path works for all environments (local + Codespaces)
VITE_API_BASE_URL=/api/v1

# Social Login – set these to enable Google / GitHub buttons on the Keycloak login page.
# After setting, log in to http://localhost/auth > Realm: rental > Identity Providers
# and enable the respective provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Environment
ENVIRONMENT=development

# Landing-Page: Demo-Zugangsdaten anzeigen
# Nur für Entwicklung / Demo-Umgebungen – in Produktion auf false setzen!
SHOW_DEMO_CREDENTIALS=true
