# PostgreSQL
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental_secret
POSTGRES_DB=rental_manager

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# Keycloak Realm / Client (used by backend + frontend)
KEYCLOAK_REALM=rental
KEYCLOAK_CLIENT_ID=rental-frontend

# Public URL of Keycloak (reachable from the browser)
VITE_KEYCLOAK_URL=http://localhost:8081

# Frontend API base
VITE_API_BASE_URL=http://localhost/api/v1

# Social Login – set these to enable Google / GitHub buttons on the Keycloak login page.
# After setting, log in to http://localhost:8081 > Realm: rental > Identity Providers
# and enable the respective provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Environment
ENVIRONMENT=development
